roadmap-2","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#stacked-bar-chart---added","content":"Stacked Bar Chart - Added!"},"62":{"id":"/docs/roadmap-3","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#line-chart---added-in-v016","content":"Line Chart - Added in v0.1.6!"},"63":{"id":"/docs/roadmap-4","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Labelling Overhaul - Added in v0.2.0!"},"64":{"id":"/docs/roadmap-5","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#framework-specific-exports","content":"Framework Specific Exports"},"65":{"id":"/docs/roadmap-6","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#accessibility","content":"Accessibility"},"66":{"id":"/docs/roadmap-7","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#additional-options","content":"Additional Options"},"67":{"id":"/docs/roadmap-8","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#maybe","content":"Maybe"},"68":{"id":"/docs/roadmap-9","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#plugins-","content":"\"Plugins\" ?"},"69":{"id":"/docs/roadmap-10","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#ascii--cli-support","content":"ASCII / CLI support"},"70":{"id":"/docs/roadmap-11","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#additional-chart-types","content":"Additional Chart Types"},"71":{"id":"/docs/roadmap-12","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#themes","content":"Themes"},"72":{"id":"/docs/roadmap-13","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#no","content":"No"},"73":{"id":"/docs/roadmap-14","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#animations","content":"Animations"},"74":{"id":"/docs/roadmap-15","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap","content":"So just as disclaimer, this is not set in stone! And there's no definitive dates for when or if pieces of what's here will arrive. As of now this whole thing is just, and while I'd like to make time for it - things don't always go the way you want day to day. Instead of a concrete roadmap, this is more of a ideas page, with a few categories - definite, maybe, and no."},"75":{"id":"/docs/roadmap-16","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#definite","content":"These are things I definitely am aiming to add and are either up next or coming soon."},"76":{"id":"/docs/roadmap-17","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#stacked-bar-chart---added","content":"From the start I've wanted to do more than just barcharts. A stacked bar chart would be simple to implement since it's the same logic as a bar chart, except you're construction each bar from a couple bars.\r\nBut I don't want to get too sucked into things here before moving on to other things."},"77":{"id":"/docs/roadmap-18","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#line-chart---added-in-v016","content":"I do plan to add line charts, but these'll be after I get to some other things!"},"78":{"id":"/docs/roadmap-19","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"In the creation of linechart - I realized that I can no longer put off having a more proper way of labelling things, that will be used in all chart-making functions."},"79":{"id":"/docs/roadmap-20","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Goals for labelling v2"},"80":{"id":"/docs/roadmap-21","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Needs to be:"},"81":{"id":"/docs/roadmap-22","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Consistent"},"82":{"id":"/docs/roadmap-23","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Flexible"},"83":{"id":"/docs/roadmap-24","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Simple to use"},"84":{"id":"/docs/roadmap-25","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"This is especially important, as making things too convoluted will go against the intended purpose of this library."},"85":{"id":"/docs/roadmap-26","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Rough list of features I'd like to add:"},"86":{"id":"/docs/roadmap-27","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"labels, mostly there already for bar charts"},"87":{"id":"/docs/roadmap-28","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"attached to"},"88":{"id":"/docs/roadmap-29","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"each bar in a bar chart"},"89":{"id":"/docs/roadmap-30","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"each line in a line chart"},"90":{"id":"/docs/roadmap-31","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"true-centered"},"91":{"id":"/docs/roadmap-32","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"need to make font an option for calculation of actual center, unless I can just use transform-origin or something."},"92":{"id":"/docs/roadmap-33","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"also allow images"},"93":{"id":"/docs/roadmap-34","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"I think this actually wouldn't be too difficult. (Surely)"},"94":{"id":"/docs/roadmap-35","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"I'm imagining an imgLabels parameter that's just an array of strings."},"95":{"id":"/docs/roadmap-36","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"If supplied placed the same as text labels."},"96":{"id":"/docs/roadmap-37","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"If supplied with normal text labels, placed above text. (maybe parameter for above or below?)"},"97":{"id":"/docs/roadmap-38","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"dataLabels, unintentionally implemented for just linechart"},"98":{"id":"/docs/roadmap-39","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"would be placed in the middle of bars:"},"99":{"id":"/docs/roadmap-40","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"above each point in a line chart"},"100":{"id":"/docs/roadmap-41","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"type would be \"literal\" or \"percentage\""},"101":{"id":"/docs/roadmap-42","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"maybe also \"percentage-per-bar\" for bar chart stacked"},"102":{"id":"/docs/roadmap-43","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"classes & coloring etc"},"103":{"id":"/docs/roadmap-44","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports","content":"Framework specific exports like import { barchart } from 'toomanycharts/svelte' I think would be great as it could allow for framework specific utilization. I'm not 100% sure how this works, but I know this is nearly a requirement for usage for a lot of things I bet."},"104":{"id":"/docs/roadmap-45","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports","content":"I'm thinking of the following frameworks, in this order to start:"},"105":{"id":"/docs/roadmap-46","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports","content":"svelte"},"106":{"id":"/docs/roadmap-47","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports","content":"react"},"107":{"id":"/docs/roadmap-48","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports","content":"solid"},"108":{"id":"/docs/roadmap-49","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports","content":"vue"},"109":{"id":"/docs/roadmap-50","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports","content":"angular"},"110":{"id":"/docs/roadmap-51","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#accessibility","content":"I'm not an expert on accessibility but I believe it wouldn't be a huge amount of work, and would be nice to have! More research needed here on what meaningful accessibility pieces can be added."},"111":{"id":"/docs/roadmap-52","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-options","content":"There's already quite a few different options available, and I plan to add some more. I don't want to get too crazy with it, because I can see that being an issue but there'll probably be some more."},"112":{"id":"/docs/roadmap-53","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-options","content":"At the very least I plan to do my best documenting everything clearly and provide examples of everything, while maintaining the core simple chart functionality."},"113":{"id":"/docs/roadmap-54","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-options","content":"I've also intentionally left out some options, like stroke, why? Because it's possible to control via CSS and I think using CSS for some more of the visual aspect of things may be better in the long run anyway."},"114":{"id":"/docs/roadmap-55","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#maybe","content":"These are things I'm considering, but not necessarily committed to."},"115":{"id":"/docs/roadmap-56","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"Chart.JS & some other libraries do this, but it's basically like small bits of additional functionality that are optional. It could look something like:"},"116":{"id":"/docs/roadmap-57","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"or something like that. But I've had a couple ideas pop in my head that sound nice but also out of scope for the core goal of the lib. In no particular order here's a couple:"},"117":{"id":"/docs/roadmap-58","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"legend"},"118":{"id":"/docs/roadmap-59","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"Would auto-generate a legend to go along with the chart, likely utilizing <fieldset>!"},"119":{"id":"/docs/roadmap-60","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"hover"},"120":{"id":"/docs/roadmap-61","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"Some sort of hover-tooltip for visuals, likely utilizing the new popover API. Ideally would use, anchor-positioning but not enough browser support for that just yet."},"121":{"id":"/docs/roadmap-62","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"click-to-save"},"122":{"id":"/docs/roadmap-63","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"A small button(s) would be tacked onto resulting charts that'd allow for saving the chart as a png or svg"},"123":{"id":"/docs/roadmap-64","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"This would be pretty easy to do as well I think, considering making this part of the core lib but leaving it here for now"},"124":{"id":"/docs/roadmap-65","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#ascii--cli-support","content":"This is definitely a tougher thing to tackle, but I personally love terminals, and would really like to be able to spit out ASCII charts for TUIs!"},"125":{"id":"/docs/roadmap-66","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#ascii--cli-support","content":"I do have an idea in mind utilizing some modern-terminal tricks, but we'll see!"},"126":{"id":"/docs/roadmap-67","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"There are many types of charts out there, and while some are definitely too complex I can think of a few that'd be doable! Here's a couple in no particular order"},"127":{"id":"/docs/roadmap-68","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Histograms"},"128":{"id":"/docs/roadmap-69","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Mirrored bar charts"},"129":{"id":"/docs/roadmap-70","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Pie charts"},"130":{"id":"/docs/roadmap-71","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Scatter plots"},"131":{"id":"/docs/roadmap-72","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Radar charts"},"132":{"id":"/docs/roadmap-73","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Pie / Donut charts"},"133":{"id":"/docs/roadmap-74","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#themes","content":"Not really a priority at all now, but it'd be easy to tack on some predefined 'themes' in the form of color palettes. This is also something that might be added in the core lib in the future if it's simple & has a small footprint."},"134":{"id":"/docs/roadmap-75","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#no","content":"These are things that I've considered and decided against. Which for now is just one thing, but this list may grow larger."},"135":{"id":"/docs/roadmap-76","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#animations","content":"This may be a bit surprising, but animations are their own can of worms. Animating things in all sorts of ways on the web is actually one of, if not my favorite thing to do in the vast world of web dev. But having that built-into the library feels like it'd be doing way too much."},"136":{"id":"/docs/roadmap-77","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#animations","content":"Additionally, because of the nature of inlined SVGs, they should play nicely with existing animation engines. In fact I plan to include some examples of doing exactly that later!"},"137":{"id":"/docs/why-toomanycharts","page_id":"/docs/why-toomanycharts","type":"page","content":"Why TooManyCharts?","breadcrumbs":["The Lib","Introduction"],"tags":[],"url":"/docs/why-toomanycharts"},"138":{"id":"/docs/why-toomanycharts-0","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts","content":"What's the point of this library?"},"139":{"id":"/docs/why-toomanycharts-1","page_id":"/docs/why-toomanycharts","type":"heading","tags":[],"url":"/docs/why-toomanycharts#motivation","content":"Motivation"},"140":{"id":"/docs/why-toomanycharts-2","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"Chart \r\n/CHärt/> a sheet of information\r\nin the form of a table, graph, or diagram."},"141":{"id":"/docs/why-toomanycharts-3","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"It's no secret that there are already many, time-tested libraries & tools out there capable of making highly complex, beautiful charts & more - many offer a multitude of data visualization options."},"142":{"id":"/docs/why-toomanycharts-4","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"Some of my favorites:"},"143":{"id":"/docs/why-toomanycharts-5","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"Chart.js"},"144":{"id":"/docs/why-toomanycharts-6","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"a feature rich, modular library for crafting many types of charts with tons of options"},"145":{"id":"/docs/why-toomanycharts-7","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"d3.js"},"146":{"id":"/docs/why-toomanycharts-8","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"one of the most powerful data visualization options out there, going way beyond charts"},"147":{"id":"/docs/why-toomanycharts-9","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"ApexCharts.js"},"148":{"id":"/docs/why-toomanycharts-10","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"a nice and cohesive chart creation lib with everything you need to create a range of charts"},"149":{"id":"/docs/why-toomanycharts-11","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"I used this way back in the day where it was totally free - looks like they\r\nhave an enterprise paid license now, good for them!"},"150":{"id":"/docs/why-toomanycharts-12","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"I have fun making any sort of visuals, and a good visual can really say a lot! But you know what else I've really come to appreciate? Simplicity! And while not a library, I do find myself utilizing google sheets quite a bit, and I came across the SPARKLINE function."},"151":{"id":"/docs/why-toomanycharts-13","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"While I haven't had a ton of opportunities as of late to utilize it, I was impressed by how simple it could be to use, and how much it could add in terms of conveying information. Let's look at some examples."},"152":{"id":"/docs/why-toomanycharts-14","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"Consider that you have the following dataset:"},"153":{"id":"/docs/why-toomanycharts-15","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"Now if you wanted a sense of how the data was trending, or changing over those cells you need to read each one to get that sense, which is fine. But what if you had 30 different columns, or what if the exact values weren't important? Or you just want to speed up that process?"},"154":{"id":"/docs/why-toomanycharts-16","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"Well this would help you glean that same information much quicker:"},"155":{"id":"/docs/why-toomanycharts-17","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"If you've used sheets before, you know making a chart is typically possible though not always the most cohesive experience. You highlight your data, go to \"insert\", choose \"chart\" then the type, and configure the various options. Which isn't terrible, it can also do more - but sometimes less is more."},"156":{"id":"/docs/why-toomanycharts-18","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"So that line graph though is within it's own cell, not floating on the sheet. And how does SPARKLINE come into play? Well, that's all it takes!"},"157":{"id":"/docs/why-toomanycharts-19","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"Not a bar chart, but we can make it one with just a little bit of configuration:"},"158":{"id":"/docs/why-toomanycharts-20","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"Just by adding that second argument, {\"charttype\",\"column\"} it's a whole different visual! But that's not all it can do, there's a bunch more configuration options, and even a couple more chart types docs here! and that sort of \"effort in\" to \"value out\" is what I'm aiming for here."},"159":{"id":"/docs/why-toomanycharts-21","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"So why toomanycharts? Time! I hope to create something that saves developers time,I want a library that can make meaningful simple charts, with trivial effort required. I hope this library is something more of a useful tool for quick & simple chart creation, whether it be a small panel in an admin dashboard, a placeholder until there's time to create a better chart, or even a debugging tool."},"160":{"id":"/docs/why-toomanycharts-22","page_id":"/docs/why-toomanycharts","tags":[],"type":"text","url":"/docs/why-toomanycharts#motivation","content":"If you're curious of what's to come, check out the Roadmap page for what I'm thinking of what's to come."},"161":{"id":"/docs/charts-api/barchart","page_id":"/docs/charts-api/barchart","type":"page","content":"Barchart","breadcrumbs":["The Lib","Usage","Charts APIs"],"tags":[],"url":"/docs/charts-api/barchart"},"162":{"id":"/docs/charts-api/barchart-0","page_id":"/docs/charts-api/barchart","tags":[],"type":"text","url":"/docs/charts-api/barchart","content":"The first chart type"},"163":{"id":"/docs/charts-api/barchart-1","page_id":"/docs/charts-api/barchart","type":"heading","tags":[],"url":"/docs/charts-api/barchart#barchart","content":"barchart"},"164":{"id":"/docs/charts-api/barchart-2","page_id":"/docs/charts-api/barchart","tags":[],"type":"text","url":"/docs/charts-api/barchart#barchart","content":"Breakdown of parameter options & usage."},"165":{"id":"/docs/charts-api/barchart-3","page_id":"/docs/charts-api/barchart","tags":[],"type":"text","url":"/docs/charts-api/barchart#barchart","content":"title: Important"},"166":{"id":"/docs/charts-api/barchart-4","page_id":"/docs/charts-api/barchart","tags":[],"type":"text","url":"/docs/charts-api/barchart#barchart","content":"type: warn"},"167":{"id":"/docs/charts-api/barchart-5","page_