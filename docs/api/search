keep-going","content":"Add some labels:"},"84":{"id":"/docs-14","page_id":"/docs","tags":[],"type":"text","url":"/docs#keep-going","content":"Place it on the top instead:"},"85":{"id":"/docs-15","page_id":"/docs","tags":[],"type":"text","url":"/docs#what-next","content":"<Card title=\"Explore all the options\" href=\"/docs/charts/barchart\" />"},"86":{"id":"/docs-16","page_id":"/docs","tags":[],"type":"text","url":"/docs#what-next","content":"<Card title=\"Check out a ton of example usage\" href=\"/docs/examples\" />"},"87":{"id":"/docs-17","page_id":"/docs","tags":[],"type":"text","url":"/docs#what-next","content":"<Card title=\"Open an Issue\" href=\"#\" />"},"88":{"id":"/docs-18","page_id":"/docs","tags":[],"type":"text","url":"/docs#what-next","content":"<Card title=\"Explode!\" href=\"#\" />"},"89":{"id":"/docs/roadmap","page_id":"/docs/roadmap","type":"page","content":"Roadmap","breadcrumbs":["The Lib","Introduction"],"tags":[],"url":"/docs/roadmap"},"90":{"id":"/docs/roadmap-0","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap","content":"Where're things heading?"},"91":{"id":"/docs/roadmap-1","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#definite","content":"Definite"},"92":{"id":"/docs/roadmap-2","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#stacked-bar-chart---added","content":"~~Stacked Bar Chart~~ - Added!"},"93":{"id":"/docs/roadmap-3","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#line-chart---added-in-v016","content":"~~Line Chart~~ - Added in `v0.1.6`!"},"94":{"id":"/docs/roadmap-4","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"~~Labelling Overhaul~~ - Added in `v0.2.0`!"},"95":{"id":"/docs/roadmap-5","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"Framework Specific Exports - WIP as of `v0.5.0`!!"},"96":{"id":"/docs/roadmap-6","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#accessibility","content":"Accessibility"},"97":{"id":"/docs/roadmap-7","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#additional-options","content":"Additional Options"},"98":{"id":"/docs/roadmap-8","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#maybe","content":"Maybe"},"99":{"id":"/docs/roadmap-9","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#plugins-","content":"\"Plugins\" ?"},"100":{"id":"/docs/roadmap-10","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#ascii--cli-support","content":"ASCII / CLI support"},"101":{"id":"/docs/roadmap-11","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#additional-chart-types","content":"Additional Chart Types"},"102":{"id":"/docs/roadmap-12","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#themes","content":"Themes"},"103":{"id":"/docs/roadmap-13","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#no","content":"No"},"104":{"id":"/docs/roadmap-14","page_id":"/docs/roadmap","type":"heading","tags":[],"url":"/docs/roadmap#animations","content":"Animations"},"105":{"id":"/docs/roadmap-15","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap","content":"So just as disclaimer, this is not set in stone! And there's no definitive dates for when or if pieces of what's here will arrive. As of now this whole thing is just, and while I'd like to make time for it - things don't always go the way you want day to day. Instead of a concrete roadmap, this is more of a ideas page, with a few categories - &#x2A;*definite,** &#x2A;*maybe,** and **no**."},"106":{"id":"/docs/roadmap-16","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#definite","content":"These are things I definitely am aiming to add and are either up next or coming soon."},"107":{"id":"/docs/roadmap-17","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#stacked-bar-chart---added","content":"From the start I've wanted to do more than just barcharts. A stacked bar chart would be simple to implement since it's the same logic as a bar chart, except you're construction each bar from a couple bars.\r\nBut I don't want to get too sucked into things here before moving on to other things."},"108":{"id":"/docs/roadmap-18","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#line-chart---added-in-v016","content":"I do plan to add line charts, but these'll be after I get to some other things!"},"109":{"id":"/docs/roadmap-19","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"In the creation of `linechart` - I realized that I can no longer put off having a more proper way of labelling things, that will be used in all chart-making functions."},"110":{"id":"/docs/roadmap-20","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Goals for labelling v2"},"111":{"id":"/docs/roadmap-21","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Needs to be:"},"112":{"id":"/docs/roadmap-22","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Consistent"},"113":{"id":"/docs/roadmap-23","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Flexible"},"114":{"id":"/docs/roadmap-24","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Simple to use"},"115":{"id":"/docs/roadmap-25","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"This is especially important, as making things too convoluted will go against the intended purpose of this library."},"116":{"id":"/docs/roadmap-26","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"Rough list of features I'd like to add:"},"117":{"id":"/docs/roadmap-27","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"`labels`, mostly there already for bar charts"},"118":{"id":"/docs/roadmap-28","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"attached to"},"119":{"id":"/docs/roadmap-29","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"each bar in a bar chart"},"120":{"id":"/docs/roadmap-30","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"each line in a line chart"},"121":{"id":"/docs/roadmap-31","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"true-centered"},"122":{"id":"/docs/roadmap-32","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"need to make font an option for calculation of actual center, unless I can just use transform-origin or something."},"123":{"id":"/docs/roadmap-33","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"also allow images"},"124":{"id":"/docs/roadmap-34","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"I think this actually wouldn't be too difficult. (Surely)"},"125":{"id":"/docs/roadmap-35","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"I'm imagining an `imgLabels` parameter that's just an array of strings."},"126":{"id":"/docs/roadmap-36","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"If supplied placed the same as text labels."},"127":{"id":"/docs/roadmap-37","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"If supplied with normal text labels, placed above text. (maybe parameter for above or below?)"},"128":{"id":"/docs/roadmap-38","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"`dataLabels`, unintentionally implemented for just `linechart`"},"129":{"id":"/docs/roadmap-39","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"would be placed in the middle of bars:"},"130":{"id":"/docs/roadmap-40","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"above each point in a line chart"},"131":{"id":"/docs/roadmap-41","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"type would be `\"literal\"` or `\"percentage\"`"},"132":{"id":"/docs/roadmap-42","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"maybe also `\"percentage-per-bar\"` for bar chart stacked"},"133":{"id":"/docs/roadmap-43","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#labelling-overhaul---added-in-v020","content":"classes & coloring etc"},"134":{"id":"/docs/roadmap-44","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"**Update on this**"},"135":{"id":"/docs/roadmap-45","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"As part of the plan I've migrated the entire lib over to scoped releases, allowing for exactly this feature - framework specific exports. I haven't yet completed a framework specific implementation, but now that the foundation is here that's coming soon!!"},"136":{"id":"/docs/roadmap-46","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"I think in terms of order I'll do a release of both `svelte` & `react` at once, and then other frameworks after."},"137":{"id":"/docs/roadmap-47","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"Framework specific exports like `import { barchart } from 'toomanycharts/svelte'` I think would be great as it could allow for framework specific utilization. I'm not 100% sure how this works, but I know this is nearly a requirement for usage for a lot of things I bet."},"138":{"id":"/docs/roadmap-48","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"I'm thinking of the following frameworks, in this order to start:"},"139":{"id":"/docs/roadmap-49","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"`svelte`"},"140":{"id":"/docs/roadmap-50","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"`react`"},"141":{"id":"/docs/roadmap-51","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"`solid`"},"142":{"id":"/docs/roadmap-52","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"`vue`"},"143":{"id":"/docs/roadmap-53","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#framework-specific-exports---wip-as-of-v050","content":"`angular`"},"144":{"id":"/docs/roadmap-54","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#accessibility","content":"I'm not an expert on accessibility but I believe it wouldn't be a huge amount of work, and would be nice to have! More research needed here on what meaningful accessibility pieces can be added."},"145":{"id":"/docs/roadmap-55","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-options","content":"There's already quite a few different options available, and I plan to add some more. I don't want to get too crazy with it, because I can see that being an issue but there'll probably be some more."},"146":{"id":"/docs/roadmap-56","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-options","content":"At the very least I plan to do my best documenting everything clearly and provide examples of everything, while maintaining the core simple chart functionality."},"147":{"id":"/docs/roadmap-57","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-options","content":"I've also intentionally left out some options, like `stroke`, why? Because it's possible to control via CSS and I think using CSS for some more of the visual aspect of things may be better in the long run anyway."},"148":{"id":"/docs/roadmap-58","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#maybe","content":"These are things I'm considering, but not necessarily committed to."},"149":{"id":"/docs/roadmap-59","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"Chart.JS & some other libraries do this, but it's basically like small bits of additional functionality that are optional. It could look something like:"},"150":{"id":"/docs/roadmap-60","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"or something like that. But I've had a couple ideas pop in my head that sound nice but also out of scope for the core goal of the lib. In no particular order here's a couple:"},"151":{"id":"/docs/roadmap-61","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"legend"},"152":{"id":"/docs/roadmap-62","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"Would auto-generate a legend to go along with the chart, likely utilizing `<fieldset>`!"},"153":{"id":"/docs/roadmap-63","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"hover"},"154":{"id":"/docs/roadmap-64","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"Some sort of hover-tooltip for visuals, likely utilizing the new popover API. Ideally would use, anchor-positioning but not enough browser support for that just yet."},"155":{"id":"/docs/roadmap-65","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"click-to-save"},"156":{"id":"/docs/roadmap-66","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"A small button(s) would be tacked onto resulting charts that'd allow for saving the chart as a `png` or `svg`"},"157":{"id":"/docs/roadmap-67","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#plugins-","content":"This would be pretty easy to do as well I think, considering making this part of the core lib but leaving it here for now"},"158":{"id":"/docs/roadmap-68","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#ascii--cli-support","content":"This is definitely a tougher thing to tackle, but I personally love terminals, and would really like to be able to spit out ASCII charts for TUIs!"},"159":{"id":"/docs/roadmap-69","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#ascii--cli-support","content":"I do have an idea in mind utilizing some modern-terminal tricks, but we'll see!"},"160":{"id":"/docs/roadmap-70","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"There are many types of charts out there, and while some are definitely too complex I can think of a few that'd be doable! Here's a couple in no particular order"},"161":{"id":"/docs/roadmap-71","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Histograms"},"162":{"id":"/docs/roadmap-72","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Mirrored bar charts"},"163":{"id":"/docs/roadmap-73","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Pie charts"},"164":{"id":"/docs/roadmap-74","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Scatter plots"},"165":{"id":"/docs/roadmap-75","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Radar charts"},"166":{"id":"/docs/roadmap-76","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#additional-chart-types","content":"Pie / Donut charts"},"167":{"id":"/docs/roadmap-77","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#themes","content":"Not really a priority at all now, but it'd be easy to tack on some predefined 'themes' in the form of color palettes. This is also something that might be added in the core lib in the future if it's simple & has a small footprint."},"168":{"id":"/docs/roadmap-78","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#no","content":"These are things that I've considered and decided against. Which for now is just one thing, but this list may grow larger."},"169":{"id":"/docs/roadmap-79","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#animations","content":"This may be a bit surprising, but animations are their own can of worms. Animating things in all sorts of ways on the web is actually one of, if not my favorite thing to do in the vast world of web dev. But having that built-into the library feels like it'd be doing way too much."},"170":{"id":"/docs/roadmap-80","page_id":"/docs/roadmap","tags":[],"type":"text","url":"/docs/roadmap#animations","content":"Additionally, because of the nature of inlined SVGs, they should play nicely with existing animation engines. In fact I plan to include some examples of doing exactly that later!"},"171":{"id":"/docs/why-jgmc","page_id":"/docs/why-jgmc","type":"page","content":"Why JGMC?","breadcrumbs":["The Lib","Introduction"],"tags":[],"url":"/docs/why-jgmc"},"172":{"id":"/docs/why-jgmc-0","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc","content":"What's the point of this library?"},"173":{"id":"/docs/why-jgmc-1","page_id":"/docs/why-jgmc","type":"heading","tags":[],"url":"/docs/why-jgmc#motivation","content":"Motivation"},"174":{"id":"/docs/why-jgmc-2","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"Chart \r\n/CHärt/> a sheet of information\r\nin the form of a table, graph, or diagram."},"175":{"id":"/docs/why-jgmc-3","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"It's no secret that there are already many, time-tested libraries & tools out there capable of making highly complex, beautiful charts & more - many offer a multitude of data visualization options."},"176":{"id":"/docs/why-jgmc-4","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"Some of my favorites:"},"177":{"id":"/docs/why-jgmc-5","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"Chart.js"},"178":{"id":"/docs/why-jgmc-6","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"a feature rich, modular library for crafting many types of charts with tons of options"},"179":{"id":"/docs/why-jgmc-7","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"d3.js"},"180":{"id":"/docs/why-jgmc-8","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"one of the most powerful data visualization options out there, going way beyond charts"},"181":{"id":"/docs/why-jgmc-9","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"ApexCharts.js"},"182":{"id":"/docs/why-jgmc-10","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"a nice and cohesive chart creation lib with everything you need to create a range of charts"},"183":{"id":"/docs/why-jgmc-11","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"I used this way back in the day where it was totally free - looks like they\r\nhave an enterprise paid license now, good for them!"},"184":{"id":"/docs/why-jgmc-12","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"I have fun making any sort of visuals, and a good visual can really say a lot! But you know what else I've really come to appreciate? Simplicity! And while not a library, I do find myself utilizing google sheets quite a bit, and I came across the `SPARKLINE` function."},"185":{"id":"/docs/why-jgmc-13","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"While I haven't had a ton of opportunities as of late to utilize it, I was impressed by how simple it could be to use, and how much it could add in terms of conveying information. Let's look at some examples."},"186":{"id":"/docs/why-jgmc-14","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"Consider that you have the following dataset:"},"187":{"id":"/docs/why-jgmc-15","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"Now if you wanted a sense of how the data was trending, or changing over those cells you need to read each one to get that sense, which is fine. But what if you had 30 different columns, or what if the exact values weren't important? Or you just want to speed up that process?"},"188":{"id":"/docs/why-jgmc-16","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"Well this would help you glean that same information much quicker:"},"189":{"id":"/docs/why-jgmc-17","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"If you've used sheets before, you know making a chart is typically possible though not always the most cohesive experience. You highlight your data, go to \"insert\", choose \"chart\" then the type, and configure the various options. Which isn't terrible, it can also do more - but sometimes less is more."},"190":{"id":"/docs/why-jgmc-18","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"So that line graph though is within it's own cell, not floating on the sheet. And how does `SPARKLINE` come into play? Well, that's all it takes!"},"191":{"id":"/docs/why-jgmc-19","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"Not a bar chart, but we can make it one with just a little bit of configuration:"},"192":{"id":"/docs/why-jgmc-20","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"Just by adding that second argument, `{\"charttype\",\"column\"}` it's a whole different visual! But that's not all it can do, there's a bunch more configuration options, and even a couple more chart types docs here! and that sort of \"effort in\" to \"value out\" is what I'm aiming for here."},"193":{"id":"/docs/why-jgmc-21","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"So why toomanycharts? Time! I hope to create something that saves developers time,I want a library that can make meaningful simple charts, with trivial effort required. I hope this library is something more of a useful tool for quick & simple chart creation, whether it be a small panel in an admin dashboard, a placeholder until there's time to create a better chart, or even a debugging tool."},"194":{"id":"/docs/why-jgmc-22","page_id":"/docs/why-jgmc","tags":[],"type":"text","url":"/docs/why-jgmc#motivation","content":"If you're curious of what's to come, check out the Roadmap page for what I'm thinking of what's to come."},"195":{"id":"/docs/examples/ascii-barchart-examples","page_id":"/docs/examples/ascii-barchart-examples","type":"page","content":"AsciiBarchart Examples","breadcrumbs":["The Lib","Usage","Charts Examples"],"tags":[],"url":"/docs/examples/ascii-barchart-examples"},"196":{"id":"/docs/examples/ascii-barchart-examples-0","page_id":"/docs/examples/ascii-barchart-examples","tags":[],"type":"text","url":"/docs/examples/ascii-barchart-examples","content":"Text-based barchart for terminal output!"},"197":{"id":"/docs/examples/ascii-barchart-examples-1","page_id":"/docs/examples/ascii-barchart-examples","type":"heading","tags":[],"url":"/docs/examples/ascii-barchart-examples#asciibarchart","content":"`asciiBarchart`"},"198":{"id":"/docs/examples/ascii-barchart-examples-2","page_id":"/docs/examples/ascii-barchart-examples","tags":[],"type":"text","url":"/docs/examples/ascii-barchart-examples#asciibarchart","content":"To be filled in! Paused to focus on library migration."},"199":{"id":"/docs/examples/barchart-examples","page_id":"/docs/examples/barchart-examples","type":"page","content":"Barchart Examples","breadcrumbs":["The Lib","Usage","Charts Examples"],"tags":[],"url":"/docs/examples/barchart-examples"},"200":{"id":"/docs/examples/barchart-examples-0","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples","content":"The first chart type"},"201":{"id":"/docs/examples/barchart-examples-1","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#barchart","content":"`barchart`"},"202":{"id":"/docs/examples/barchart-examples-2","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#from-quick-start","content":"From Quick Start"},"203":{"id":"/docs/examples/barchart-examples-3","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#larger-data-values","content":"Larger Data Values"},"204":{"id":"/docs/examples/barchart-examples-4","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#coloring","content":"Coloring"},"205":{"id":"/docs/examples/barchart-examples-5","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#basic-coloring","content":"Basic Coloring"},"206":{"id":"/docs/examples/barchart-examples-6","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#gradients","content":"Gradients"},"207":{"id":"/docs/examples/barchart-examples-7","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#animation","content":"Animation"},"208":{"id":"/docs/examples/barchart-examples-8","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#animejs","content":"Animejs"},"209":{"id":"/docs/examples/barchart-examples-9","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#breakdown","content":"Breakdown"},"210":{"id":"/docs/examples/barchart-examples-10","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#transformorigin-guide","content":"`transformOrigin` guide"},"211":{"id":"/docs/examples/barchart-examples-11","page_id":"/docs/examples/barchart-examples","type":"heading","tags":[],"url":"/docs/examples/barchart-examples#try-it-out","content":"Try It Out!"},"212":{"id":"/docs/examples/barchart-examples-12","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#barchart","content":"Loads of examples!"},"213":{"id":"/docs/examples/barchart-examples-13","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#barchart","content":"Just a reminder that `barchart` returns an SVG, so to use the output you'll want to add it to the DOM however your framework of choice handles it."},"214":{"id":"/docs/examples/barchart-examples-14","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#from-quick-start","content":"The most basic possible usage:"},"215":{"id":"/docs/examples/barchart-examples-15","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#from-quick-start","content":"Adding some labels:"},"216":{"id":"/docs/examples/barchart-examples-16","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#from-quick-start","content":"And let's place it on the top:"},"217":{"id":"/docs/examples/barchart-examples-17","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#larger-data-values","content":"If one bar is far larger than the others, the resulting zoomed out to fit the largest bar, showing a sense of scale."},"218":{"id":"/docs/examples/barchart-examples-18","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#larger-data-values","content":"Placed on the top:"},"219":{"id":"/docs/examples/barchart-examples-19","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#coloring","content":"Adding colors is straightforward too!"},"220":{"id":"/docs/examples/barchart-examples-20","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#basic-coloring","content":"Below only `2` colors are provided, but `3` datapoints are given. When there are less colors than datapoints, the colors will alternate for the remaining datapoints."},"221":{"id":"/docs/examples/barchart-examples-21","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#gradients","content":"Providing a few colors in the `gradientColors` array will result in each bar getting a linear gradient with evenly spaced stops based on the number of colors given."},"222":{"id":"/docs/examples/barchart-examples-22","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#gradients","content":"In the below example I've set the resulting SVG's height & width to be the same as datapoints to show the colored bars."},"223":{"id":"/docs/examples/barchart-examples-23","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#gradients","content":"The linear gradient that's created automatically spreads the color stops evenly, from the start of the array of colors to the end. So giving it two colors like above results in stops like so:"},"224":{"id":"/docs/examples/barchart-examples-24","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#gradients","content":"The nice thing is that any valid CSS color should work, here's an example using `oklch` instead:"},"225":{"id":"/docs/examples/barchart-examples-25","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#gradients","content":"And another thing I added that I think is pretty cool is having a continuous gradient that's created with a bit of masking!"},"226":{"id":"/docs/examples/barchart-examples-26","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#gradients","content":"To do this the `gradientMode` should be `\"continuos\"` & the `gradientDirection` can be whatever way you want it, here I've set it to match the top-side bar placement."},"227":{"id":"/docs/examples/barchart-examples-27","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#animation","content":"Because JGMC outputs SVG strings that you can instantly turn into a valid SVG element, they can be animated! The caveat is that to animate the individual bars, depending on what sort of animation you want to do, you'll need to change the `transform-origin` for bars after the charts created based on which side they're on. Which sounds more complicated than it is!"},"228":{"id":"/docs/examples/barchart-examples-28","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#animejs","content":"Let's look at an example, where to have the bars 'grow in' we'll need to do exactly that. I'll use my animation engine lib of choice -  animejs !"},"229":{"id":"/docs/examples/barchart-examples-29","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#animejs","content":"Results in:"},"230":{"id":"/docs/examples/barchart-examples-30","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#breakdown","content":"`main.ts` is just appending the chart to the page."},"231":{"id":"/docs/examples/barchart-examples-31","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#breakdown","content":"`script.ts` does a few things, here's a commented version of it:"},"232":{"id":"/docs/examples/barchart-examples-32","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#breakdown","content":"You may have noticed that there's a bit of a 'flicker' above - this is a known issue. It happens because the order of things as it currently stands, which goes something like:"},"233":{"id":"/docs/examples/barchart-examples-33","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#breakdown","content":"Page loads"},"234":{"id":"/docs/examples/barchart-examples-34","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#breakdown","content":"Chart created, added to page"},"235":{"id":"/docs/examples/barchart-examples-35","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#breakdown","content":"At this point it looks normal with all bars full-width"},"236":{"id":"/docs/examples/barchart-examples-36","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#breakdown","content":"`100ms` after, `scaleX` set to `0` so now the bars are suddenly gone, causing a flicker"},"237":{"id":"/docs/examples/barchart-examples-37","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#breakdown","content":"The fix here is simple, and coming soon. I will add a `barStyle` option which will allow you to set inline styles for each bar, which'll get tacked onto them - avoiding the flicker."},"238":{"id":"/docs/examples/barchart-examples-38","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#breakdown","content":"All that being said, the `transform-origin` is only relevant when you're moving the bars in some way, something like `opacity` or `fill` wouldn't require that at all."},"239":{"id":"/docs/examples/barchart-examples-39","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#transformorigin-guide","content":"Regardless, here's a table & visual guide for all placement options!"},"240":{"id":"/docs/examples/barchart-examples-40","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#transformorigin-guide","content":"placement"},"241":{"id":"/docs/examples/barchart-examples-41","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#transformorigin-guide","content":"`transformOrigin` keywords"},"242":{"id":"/docs/examples/barchart-examples-42","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#transformorigin-guide","content":"\"top\""},"243":{"id":"/docs/examples/barchart-examples-43","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#transformorigin-guide","content":"\"top center\""},"244":{"id":"/docs/examples/barchart-examples-44","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#transformorigin-guide","content":"\"right\""},"245":{"id":"/docs/examples/barchart-examples-45","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#transformorigin-guide","content":"\"right center\""},"246":{"id":"/docs/examples/barchart-examples-46","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#transformorigin-guide","content":"\"bottom\""},"247":{"id":"/docs/examples/barchart-examples-47","page_id":"/docs/examples/barchart-examples","tags":[],"type":"text","url":"/docs/examples/barchart-examples#transformorigin-guide","content":"\"bottom center\""},"248":{"id":"/docs/examples/barchart-examples-48","page_id":"