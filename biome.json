{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"src/**/*.ts",
			"tests/**/*.ts",
			"packages/**/*.ts",
			"packages/**/*.tsx",
			"scripts/**/*.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noConsole": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["packages/react/**/*.ts", "packages/react/**/*.tsx"],
			"javascript": {
				"jsxRuntime": "transparent",
				"formatter": {
					"jsxQuoteStyle": "double"
				}
			},
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "warn",
						"noUnusedImports": "warn"
					}
				}
			}
		}
	]
}
