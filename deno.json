{
  "tasks": {
    "go": "deno task --recursive dev",
    "godev": {
      "command": "watchexec --restart --exts ts -- deno task go",
      "description": "Uses watchexec to restart the recursive dev command running both the root-level 'dev' which runs all tests but also the gallery server for output visual inspection "
    },
    "dev": "deno test --allow-write --allow-read --allow-env tests",
    "devone": {
      "command": "deno test --watch --allow-write --allow-read --allow-env tests/asciibarchart.test.ts",
      "description": "Runs a single test file in watch mode"
    },
    "cov": "deno test tests/ --allow-write --allow-read --coverage=coverage",
    "covdev": {
      "command": "watchexec --restart --exts ts -- deno task cov",
      "description": "Uses watchexec to restart coverage testing on change"
    },
    "format": "deno run -A npm:@biomejs/biome format --write",
    "lint": "deno run -A npm:@biomejs/biome lint --write",
    "check": "deno run -A npm:@biomejs/biome check --write",
    "checkf": "deno run -A npm:@biomejs/biome check --write --unsafe",
    "bench1k": {
      "command": "deno bench tests/speed/1k_random_allcharts.bench.ts",
      "description": "Runs benchmark for creating 1k charts with random small datasets for all chart types"
    },
    "examplebuild": {
      "command": "BUILD=true deno run -A scripts/build_npm.ts 0.0.1",
      "description": "Example command to build the npm package with a specific version"
    }
  },
  "imports": {
    "@biomejs/biome": "npm:@biomejs/biome@^2.3.11",
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3",
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/collections": "jsr:@std/collections@^1.1.3",
    "@std/fmt": "jsr:@std/fmt@^1.0.8",
    "@std/random": "jsr:@std/random@^0.1.4",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "linkedom": "npm:linkedom@^0.18.12"
  },
  "compilerOptions": {
    "lib": ["dom", "deno.ns"]
  },
  "workspace": ["e2e/gallery"]
}
